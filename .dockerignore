# Docker ignore file

# Version control
.git
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs
*.log
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test and coverage
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# Build artifacts
dist/
build/
*.egg-info/

# Documentation
docs/_build/

# Environment files
.env
.env.local
.env.*.local

# Local data (logos are mounted as volume)
favorites/logos/*
!favorites/logos/.gitkeep

# Temporary files
temp/
tmp/

# Backup files
*.bak
*.backup